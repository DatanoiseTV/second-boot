# Pinned upstream versions. Source the file from build scripts.
# Bump deliberately, then re-run 01-fetch-sources.sh.

# Mainline U-Boot. v2025.01 is the first release with the SPL fixes we
# rely on for sun5i. Bump only with intent.
UBOOT_REPO="https://source.denx.de/u-boot/u-boot.git"
UBOOT_REF="v2025.01"

# Mainline Linux. 6.12 is the current LTS (supported until Dec 2026).
# Pin to a specific point release rather than tip.
LINUX_REPO="https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git"
LINUX_REF="v6.12.20"

# sunxi-tools — for FEL mode recovery and on-host fexc/sunxi-fel.
SUNXI_TOOLS_REPO="https://github.com/linux-sunxi/sunxi-tools.git"
SUNXI_TOOLS_REF="v1.4.2"

# linux-firmware. We only cherry-pick the RTL8723BS blobs from this tree;
# we don't install the whole thing.
LINUX_FIRMWARE_REPO="https://git.kernel.org/pub/scm/linux/kernel/git/firmware/linux-firmware.git"
LINUX_FIRMWARE_REF="20250211"

# Cross toolchain prefix on the build host.
CROSS_COMPILE="arm-linux-gnueabihf-"
ARCH="arm"

# Build host paths (used by scripts running ON the remote build VM).
BUILD_ROOT="${BUILD_ROOT:-$HOME/pocketchip-build}"
SOURCES_DIR="${BUILD_ROOT}/sources"
ARTIFACTS_DIR="${BUILD_ROOT}/artifacts"

# Parallelism for kernel/uboot builds.
NPROC="$(nproc 2>/dev/null || echo 4)"
