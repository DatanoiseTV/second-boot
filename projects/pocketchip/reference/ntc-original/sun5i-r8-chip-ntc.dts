		timer@01c60000 {
			compatible = "allwinner,sun5i-a13-hstimer";
			reg = <0x1c60000 0x1000>;
			interrupts = <0x52 0x53>;
			clocks = <0x02 0x1c>;
		};

		lcd-controller@01c0c000 {
			compatible = "allwinner,sun5i-a13-tcon";
			reg = <0x1c0c000 0x1000>;
			interrupts = <0x2c>;
			resets = <0x04 0x01>;
			reset-names = "lcd";
			clocks = <0x02 0x24 0x04 0x06>;
			clock-names = "ahb", "tcon-ch0", "tcon-ch1";
			clock-output-names = "tcon-pixel-clock";
			status = "okay";
			linux,phandle = <0x7a>;
			phandle = <0x7a>;

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				port@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;
					linux,phandle = <0x7b>;
					phandle = <0x7b>;

					endpoint@0 {
						reg = <0x00>;
						remote-endpoint = <0x3a>;
						linux,phandle = <0x3f>;
						phandle = <0x3f>;
					};
				};

				port@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;
					linux,phandle = <0x7c>;
					phandle = <0x7c>;

					endpoint@1 {
						reg = <0x01>;
						remote-endpoint = <0x3b>;
						linux,phandle = <0x40>;
						phandle = <0x40>;
					};
				};
			};
		};

		pwm@01c20e00 {
			compatible = "allwinner,sun5i-a13-pwm";
			reg = <0x1c20e00 0x0c>;
			clocks = <0x09>;
			#pwm-cells = <0x03>;
			status = "disabled";
			linux,phandle = <0x7d>;
			phandle = <0x7d>;
		};

		display-frontend@01e00000 {
			compatible = "allwinner,sun5i-a13-display-frontend";
			reg = <0x1e00000 0x20000>;
			interrupts = <0x2f>;
			clocks = <0x02 0x2e 0x3c 0x05 0x19>;
			clock-names = "ahb", "mod", "ram";
			resets = <0x3c>;
			status = "disabled";
			linux,phandle = <0x45>;
			phandle = <0x45>;

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				port@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;
					linux,phandle = <0x7e>;
					phandle = <0x7e>;

					endpoint@0 {
						reg = <0x00>;
						remote-endpoint = <0x3d>;
						linux,phandle = <0x3e>;
						phandle = <0x3e>;
					};
				};
			};
		};

		display-backend@01e60000 {
			compatible = "allwinner,sun5i-a13-display-backend";
			reg = <0x1e60000 0x10000>;
			clocks = <0x02 0x2c 0x03 0x05 0x1a>;
			clock-names = "ahb", "mod", "ram";
			resets = <0x03>;
			status = "okay";
			assigned-clocks = <0x03>;
			assigned-clock-rates = <0x11e1a300>;
			linux,phandle = <0x7f>;
			phandle = <0x7f>;

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				port@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;
					linux,phandle = <0x80>;
					phandle = <0x80>;

					endpoint@0 {
						reg = <0x00>;
						remote-endpoint = <0x3e>;
						linux,phandle = <0x3d>;
						phandle = <0x3d>;
					};
				};

				port@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;
					linux,phandle = <0x81>;
					phandle = <0x81>;

					endpoint@0 {
						reg = <0x00>;
						remote-endpoint = <0x3f>;
						linux,phandle = <0x3a>;
						phandle = <0x3a>;
					};
				};
			};
		};

		tv-encoder@01c0a000 {
			compatible = "allwinner,sun4i-a10-tv-encoder";
			reg = <0x1c0a000 0x1000>;
			clocks = <0x02 0x22>;
			resets = <0x04 0x00>;
			status = "okay";
			linux,phandle = <0x82>;
			phandle = <0x82>;

			port {
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				endpoint@0 {
					reg = <0x00>;
					remote-endpoint = <0x40>;
					linux,phandle = <0x3b>;
					phandle = <0x3b>;
				};
			};
		};

		gpu@01c40000 {
			compatible = "arm,mali-400", "arm,mali-utgard";
			reg = <0x1c40000 0x10000>;
			interrupts = <0x45 0x46 0x47 0x48 0x49>;
			interrupt-names = "IRQGP", "IRQGPMMU", "IRQPP0", "IRQPPMMU0", "IRQPMU";
			clocks = <0x02 0x34 0x41>;
			clock-names = "ahb", "mod";
			resets = <0x41>;
			assigned-clocks = <0x41>;
			assigned-clock-rates = <0x1298be00>;
			linux,phandle = <0x83>;
			phandle = <0x83>;
		};
	};

	thermal-zones {

		cpu_thermal {
			polling-delay-passive = <0xfa>;
			polling-delay = <0x3e8>;
			thermal-sensors = <0x42>;

			cooling-maps {

				map0 {
					trip = <0x43>;
					cooling-device = <0x44 0xffffffff 0xffffffff>;
				};
			};

			trips {

				cpu_alert0 {
					temperature = <0xcf850>;
					hysteresis = <0x7d0>;
					type = "passive";
					linux,phandle = <0x43>;
					phandle = <0x43>;
				};

				cpu_crit {
					temperature = <0x186a0>;
					hysteresis = <0x7d0>;
					type = "critical";
					linux,phandle = <0x84>;
					phandle = <0x84>;
				};
			};
		};
	};

	display-engine {
		compatible = "allwinner,sun5i-a13-display-engine";
		allwinner,pipelines = <0x45>;
	};

	ahci-5v {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x46>;
		regulator-name = "ahci-5v";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x2b 0x01 0x08 0x00>;
		status = "disabled";
		linux,phandle = <0x85>;
		phandle = <0x85>;
	};

	usb0-vbus {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x47>;
		regulator-name = "usb0-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		enable-active-high;
		gpio = <0x2b 0x01 0x0a 0x00>;
		status = "okay";
		vin-supply = <0x2e>;
		linux,phandle = <0x2d>;
		phandle = <0x2d>;
	};

	usb1-vbus {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x48>;
		regulator-name = "usb1-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x2b 0x07 0x06 0x00>;
		status = "disabled";
		linux,phandle = <0x86>;
		phandle = <0x86>;
	};

	usb2-vbus {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x49>;
		regulator-name = "usb2-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x2b 0x07 0x03 0x00>;
		status = "disabled";
		linux,phandle = <0x87>;
		phandle = <0x87>;
	};

	vcc3v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v0";
		regulator-min-microvolt = <0x2dc6c0>;
		regulator-max-microvolt = <0x2dc6c0>;
		linux,phandle = <0x31>;
		phandle = <0x31>;
	};

	vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		linux,phandle = <0x88>;
		phandle = <0x88>;
	};

	vcc5v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		linux,phandle = <0x2e>;
		phandle = <0x2e>;
	};

	leds {
		compatible = "gpio-leds";

		status {
			label = "chip:white:status";
			gpios = <0x4a 0x02 0x00>;
			default-state = "on";
			linux,default-trigger = "heartbeat";
			linux,phandle = <0x89>;
			phandle = <0x89>;
		};
	};

	mmc0_pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <0x4b>;
		reset-gpios = <0x2b 0x02 0x13 0x01>;
		linux,phandle = <0x24>;
		phandle = <0x24>;
	};

	onewire {
		compatible = "w1-gpio";
		gpios = <0x2b 0x03 0x02 0x00>;
		pinctrl-names = "default";
		pinctrl-0 = <0x4c>;
	};

	wifi_reg {
		compatible = "coupled-voltage-regulator";
		regulator-name = "vcc-wifi";
		vin0-supply = <0x4d>;
		vin1-supply = <0x4e>;
		linux,phandle = <0x23>;
		phandle = <0x23>;
	};

