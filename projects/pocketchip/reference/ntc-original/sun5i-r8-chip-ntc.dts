/dts-v1/;

/ {
	#address-cells = <0x01>;
	#size-cells = <0x01>;
	interrupt-parent = <0x01>;
	model = "NextThing C.H.I.P.";
	compatible = "nextthing,chip", "allwinner,sun5i-r8";

	chosen {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;
		stdout-path = "serial0:115200n8";

		framebuffer@0 {
			compatible = "allwinner,simple-framebuffer", "simple-framebuffer";
			allwinner,pipeline = "de_be0-lcd0";
			clocks = <0x02 0x24 0x02 0x2c 0x03 0x04 0x05 0x1a>;
			status = "disabled";
		};

		framebuffer@1 {
			compatible = "allwinner,simple-framebuffer", "simple-framebuffer";
			allwinner,pipeline = "de_be0-lcd0-tve0";
			clocks = <0x02 0x22 0x02 0x24 0x02 0x2c 0x03 0x06 0x05 0x1a>;
			status = "disabled";
		};
	};

	aliases {
		i2c0 = "/soc@01c00000/i2c@01c2ac00";
		i2c1 = "/soc@01c00000/i2c@01c2b000";
		i2c2 = "/soc@01c00000/i2c@01c2b400";
		serial0 = "/soc@01c00000/serial@01c28400";
		serial1 = "/soc@01c00000/serial@01c28c00";
	};

	memory {
		device_type = "memory";
		reg = <0x00 0x00>;
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a8";
			reg = <0x00>;
			clocks = <0x07>;
			clock-latency = <0x3b9b0>;
			operating-points = <0xf6180 0x155cc0 0xdea80 0x149970 0xd2f00 0x13d620 0x98580 0x124f80 0x8ca00 0x124f80 0x69780 0x124f80>;
			#cooling-cells = <0x02>;
			cooling-min-level = <0x00>;
			cooling-max-level = <0x05>;
			cpu-supply = <0x08>;
			linux,phandle = <0x44>;
			phandle = <0x44>;
		};
	};

	clocks {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;

		dummy {
			#clock-cells = <0x00>;
			compatible = "fixed-clock";
			clock-frequency = <0x00>;
			linux,phandle = <0x0f>;
			phandle = <0x0f>;
		};

		clk@01c20050 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-osc-clk";
			reg = <0x1c20050 0x04>;
			clock-frequency = <0x16e3600>;
			clock-output-names = "osc24M";
			linux,phandle = <0x09>;
			phandle = <0x09>;
		};

		osc3M_clk {
			compatible = "fixed-factor-clock";
			#clock-cells = <0x00>;
			clock-div = <0x08>;
			clock-mult = <0x01>;
			clocks = <0x09>;
			clock-output-names = "osc3M";
			linux,phandle = <0x0a>;
			phandle = <0x0a>;
		};

		clk@0 {
			#clock-cells = <0x00>;
			compatible = "fixed-clock";
			clock-frequency = <0x8000>;
			clock-output-names = "osc32k";
			linux,phandle = <0x0d>;
			phandle = <0x0d>;
		};

		clk@01c20000 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-pll1-clk";
			reg = <0x1c20000 0x04>;
			clocks = <0x09>;
			clock-output-names = "pll1";
			linux,phandle = <0x0e>;
			phandle = <0x0e>;
		};

		clk@01c20008 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-pll2-clk";
			reg = <0x1c20008 0x08>;
			clocks = <0x09>;
			clock-output-names = "pll2-1x", "pll2-2x", "pll2-4x", "pll2-8x";
			linux,phandle = <0x14>;
			phandle = <0x14>;
		};

		clk@01c20010 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-pll3-clk";
			reg = <0x1c20010 0x04>;
			clocks = <0x0a>;
			clock-output-names = "pll3";
			linux,phandle = <0x0b>;
			phandle = <0x0b>;
		};

		pll3x2_clk {
			compatible = "fixed-factor-clock";
			#clock-cells = <0x00>;
			clock-div = <0x01>;
			clock-mult = <0x02>;
			clocks = <0x0b>;
			clock-output-names = "pll3-2x";
			linux,phandle = <0x17>;
			phandle = <0x17>;
		};

		clk@01c20018 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-pll1-clk";
			reg = <0x1c20018 0x04>;
			clocks = <0x09>;
			clock-output-names = "pll4";
			linux,phandle = <0x19>;
			phandle = <0x19>;
		};

		clk@01c20020 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-pll5-clk";
			reg = <0x1c20020 0x04>;
			clocks = <0x09>;
			clock-output-names = "pll5_ddr", "pll5_other";
			linux,phandle = <0x13>;
			phandle = <0x13>;
		};

		clk@01c20028 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-pll6-clk";
			reg = <0x1c20028 0x04>;
			clocks = <0x09>;
			clock-output-names = "pll6_sata", "pll6_other", "pll6";
			linux,phandle = <0x11>;
			phandle = <0x11>;
		};

		clk@01c20030 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-pll3-clk";
			reg = <0x1c20030 0x04>;
			clocks = <0x0a>;
			clock-output-names = "pll7";
			linux,phandle = <0x0c>;
			phandle = <0x0c>;
		};

		pll7x2_clk {
			compatible = "fixed-factor-clock";
			#clock-cells = <0x00>;
			clock-div = <0x01>;
			clock-mult = <0x02>;
			clocks = <0x0c>;
			clock-output-names = "pll7-2x";
			linux,phandle = <0x18>;
			phandle = <0x18>;
		};

		cpu@01c20054 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-cpu-clk";
			reg = <0x1c20054 0x04>;
			clocks = <0x0d 0x09 0x0e 0x0f>;
			clock-output-names = "cpu";
			linux,phandle = <0x07>;
			phandle = <0x07>;
		};

		axi@01c20054 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-axi-clk";
			reg = <0x1c20054 0x04>;
			clocks = <0x07>;
			clock-output-names = "axi";
			linux,phandle = <0x10>;
			phandle = <0x10>;
		};

		ahb@01c20054 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun5i-a13-ahb-clk";
			reg = <0x1c20054 0x04>;
			clocks = <0x10 0x07 0x11 0x01>;
			clock-output-names = "ahb";
			assigned-clocks = <0x12>;
			assigned-clock-parents = <0x11 0x01>;
			linux,phandle = <0x12>;
			phandle = <0x12>;
		};

		apb0@01c20054 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-apb0-clk";
			reg = <0x1c20054 0x04>;
			clocks = <0x12>;
			clock-output-names = "apb0";
			linux,phandle = <0x15>;
			phandle = <0x15>;
		};

		clk@01c20058 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-apb1-clk";
			reg = <0x1c20058 0x04>;
			clocks = <0x09 0x11 0x01 0x0d>;
			clock-output-names = "apb1";
			linux,phandle = <0x16>;
			phandle = <0x16>;
		};

		clk@01c2005c {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-axi-gates-clk";
			reg = <0x1c2005c 0x04>;
			clocks = <0x10>;
			clock-indices = <0x00>;
			clock-output-names = "axi_dram";
			linux,phandle = <0x4f>;
			phandle = <0x4f>;
		};

		clk@01c20080 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c20080 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "nand";
			linux,phandle = <0x1a>;
			phandle = <0x1a>;
		};

		clk@01c20084 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c20084 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "ms";
			linux,phandle = <0x50>;
			phandle = <0x50>;
		};

		clk@01c20088 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-mmc-clk";
			reg = <0x1c20088 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "mmc0", "mmc0_output", "mmc0_sample";
			linux,phandle = <0x21>;
			phandle = <0x21>;
		};

		clk@01c2008c {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-mmc-clk";
			reg = <0x1c2008c 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "mmc1", "mmc1_output", "mmc1_sample";
			linux,phandle = <0x25>;
			phandle = <0x25>;
		};

		clk@01c20090 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-mmc-clk";
			reg = <0x1c20090 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "mmc2", "mmc2_output", "mmc2_sample";
			linux,phandle = <0x26>;
			phandle = <0x26>;
		};

		clk@01c20098 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c20098 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "ts";
			linux,phandle = <0x51>;
			phandle = <0x51>;
		};

		clk@01c2009c {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c2009c 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "ss";
			linux,phandle = <0x52>;
			phandle = <0x52>;
		};

		clk@01c200a0 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c200a0 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "spi0";
			linux,phandle = <0x1f>;
			phandle = <0x1f>;
		};

		clk@01c200a4 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c200a4 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "spi1";
			linux,phandle = <0x20>;
			phandle = <0x20>;
		};

		clk@01c200a8 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c200a8 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "spi2";
			linux,phandle = <0x2f>;
			phandle = <0x2f>;
		};

		clk@01c200b0 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-mod0-clk";
			reg = <0x1c200b0 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "ir0";
			linux,phandle = <0x53>;
			phandle = <0x53>;
		};

		clk@01c200cc {
			#clock-cells = <0x01>;
			#reset-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-usb-clk";
			reg = <0x1c200cc 0x04>;
			clocks = <0x11 0x01>;
			clock-output-names = "usb_ohci0", "usb_phy";
			linux,phandle = <0x29>;
			phandle = <0x29>;
		};

		clk@01c20140 {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-codec-clk";
			reg = <0x1c20140 0x04>;
			clocks = <0x14 0x00>;
			clock-output-names = "codec";
			linux,phandle = <0x32>;
			phandle = <0x32>;
		};

		clk@01c2015c {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun5i-a13-mbus-clk";
			reg = <0x1c2015c 0x04>;
			clocks = <0x09 0x11 0x01 0x13 0x01>;
			clock-output-names = "mbus";
			linux,phandle = <0x54>;
			phandle = <0x54>;
		};

		clk@01c20060 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-ahb-gates-clk";
			reg = <0x1c20060 0x08>;
			clocks = <0x12>;
			clock-indices = <0x00 0x01 0x02 0x05 0x06 0x07 0x08 0x09 0x0a 0x0d 0x0e 0x14 0x15 0x16 0x1c 0x20 0x22 0x24 0x28 0x2c 0x2e 0x33 0x34>;
			clock-output-names = "ahb_usbotg", "ahb_ehci", "ahb_ohci", "ahb_ss", "ahb_dma", "ahb_bist", "ahb_mmc0", "ahb_mmc1", "ahb_mmc2", "ahb_nand", "ahb_sdram", "ahb_spi0", "ahb_spi1", "ahb_spi2", "ahb_stimer", "ahb_ve", "ahb_tve", "ahb_lcd", "ahb_csi", "ahb_de_be", "ahb_de_fe", "ahb_iep", "ahb_mali400";
			linux,phandle = <0x02>;
			phandle = <0x02>;
		};

		clk@01c20068 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-apb0-gates-clk";
			reg = <0x1c20068 0x04>;
			clocks = <0x15>;
			clock-indices = <0x00 0x05 0x06>;
			clock-output-names = "apb0_codec", "apb0_pio", "apb0_ir";
			linux,phandle = <0x30>;
			phandle = <0x30>;
		};

		clk@01c2006c {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-apb1-gates-clk";
			reg = <0x1c2006c 0x04>;
			clocks = <0x16>;
			clock-indices = <0x00 0x01 0x02 0x11 0x13>;
			clock-output-names = "apb1_i2c0", "apb1_i2c1", "apb1_i2c2", "apb1_uart1", "apb1_uart3";
			linux,phandle = <0x33>;
			phandle = <0x33>;
		};

		clk@01c20100 {
			#clock-cells = <0x01>;
			compatible = "allwinner,sun5i-a13-dram-gates-clk", "allwinner,sun4i-a10-gates-clk";
			reg = <0x1c20100 0x04>;
			clocks = <0x13 0x00>;
			clock-indices = <0x00 0x01 0x19 0x1a 0x1d 0x1f>;
			clock-output-names = "dram_ve", "dram_csi", "dram_de_fe", "dram_de_be", "dram_ace", "dram_iep";
			linux,phandle = <0x05>;
			phandle = <0x05>;
		};

		clk@01c20104 {
			#clock-cells = <0x00>;
			#reset-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-display-clk";
			reg = <0x1c20104 0x04>;
			clocks = <0x0b 0x0c 0x13 0x01>;
			clock-output-names = "de-be";
			linux,phandle = <0x03>;
			phandle = <0x03>;
		};

		clk@01c2010c {
			#clock-cells = <0x00>;
			#reset-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-display-clk";
			reg = <0x1c2010c 0x04>;
			clocks = <0x0b 0x0c 0x13 0x01>;
			clock-output-names = "de-fe";
			linux,phandle = <0x3c>;
			phandle = <0x3c>;
		};

		clk@01c20118 {
			#clock-cells = <0x00>;
			#reset-cells = <0x01>;
			compatible = "allwinner,sun4i-a10-tcon-ch0-clk";
			reg = <0x1c20118 0x04>;
			clocks = <0x0b 0x0c 0x17 0x18>;
			clock-output-names = "tcon-ch0-sclk";
			linux,phandle = <0x04>;
			phandle = <0x04>;
		};

		clk@01c2012c {
			#clock-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-tcon-ch1-clk";
			reg = <0x1c2012c 0x04>;
			clocks = <0x0b 0x0c 0x17 0x18>;
			clock-output-names = "tcon-ch1-sclk";
			linux,phandle = <0x06>;
			phandle = <0x06>;
		};

		clk@01c20154 {
			#clock-cells = <0x00>;
			#reset-cells = <0x00>;
			compatible = "allwinner,sun4i-a10-gpu-clk";
			reg = <0x1c20154 0x04>;
			clocks = <0x0b 0x19 0x13 0x01 0x0c 0x18>;
			clock-output-names = "mali";
			linux,phandle = <0x41>;
			phandle = <0x41>;
		};
	};

	soc@01c00000 {
		compatible = "simple-bus";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;

		sram-controller@01c00000 {
			compatible = "allwinner,sun4i-a10-sram-controller";
			reg = <0x1c00000 0x30>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges;

			sram@00000000 {
				compatible = "mmio-sram";
				reg = <0x00 0xc000>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				ranges = <0x00 0x00 0xc000>;
				linux,phandle = <0x55>;
				phandle = <0x55>;
			};

			sram@00010000 {
				compatible = "mmio-sram";
				reg = <0x10000 0x1000>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				ranges = <0x00 0x10000 0x1000>;
				linux,phandle = <0x56>;
				phandle = <0x56>;

				sram-section@0000 {
					compatible = "allwinner,sun4i-a10-sram-d";
					reg = <0x00 0x1000>;
					status = "okay";
					linux,phandle = <0x28>;
					phandle = <0x28>;
				};
			};
		};

		dma-controller@01c02000 {
			compatible = "allwinner,sun4i-a10-dma";
			reg = <0x1c02000 0x1000>;
			interrupts = <0x1b>;
			clocks = <0x02 0x06>;
			#dma-cells = <0x02>;
			linux,phandle = <0x1e>;
			phandle = <0x1e>;
		};

		nand@01c03000 {
			compatible = "allwinner,sun4i-a10-nand";
			reg = <0x1c03000 0x1000>;
			interrupts = <0x25>;
			clocks = <0x02 0x0d 0x1a>;
			clock-names = "ahb", "mod";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			status = "okay";
			pinctrl-names = "default";
			pinctrl-0 = <0x1b 0x1c 0x1d>;
			dmas = <0x1e 0x01 0x03>;
			dma-names = "rxtx";
			linux,phandle = <0x57>;
			phandle = <0x57>;

			nand@0 {
				#address-cells = <0x02>;
				#size-cells = <0x02>;
				reg = <0x00>;
				allwinner,rb = <0x00>;
				nand-ecc-mode = "hw";

				spl@0 {
					label = "SPL";
					reg = <0x00 0x00 0x00 0x400000>;
				};

				spl-backup@400000 {
					label = "SPL.backup";
					reg = <0x00 0x400000 0x00 0x400000>;
				};

				u-boot@800000 {
					label = "U-Boot";
					reg = <0x00 0x800000 0x00 0x400000>;
				};

				env@c00000 {
					label = "env";
					reg = <0x00 0xc00000 0x00 0x400000>;
				};

				rootfs@1000000 {
					label = "rootfs";
					reg = <0x00 0x1000000 0x01 0xff000000>;
				};
			};
		};

		spi@01c05000 {
			compatible = "allwinner,sun4i-a10-spi";
			reg = <0x1c05000 0x1000>;
			interrupts = <0x0a>;
			clocks = <0x02 0x14 0x1f>;
			clock-names = "ahb", "mod";
