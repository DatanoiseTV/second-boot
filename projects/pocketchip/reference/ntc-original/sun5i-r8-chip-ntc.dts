	__local_fixups__ {
		interrupt-parent = <0x00>;

		chosen {

			framebuffer@0 {
				clocks = <0x00 0x08 0x10 0x14 0x18>;
			};

			framebuffer@1 {
				clocks = <0x00 0x08 0x10 0x18 0x1c 0x20>;
			};
		};

		cpus {

			cpu@0 {
				clocks = <0x00>;
				cpu-supply = <0x00>;
			};
		};

		clocks {

			osc3M_clk {
				clocks = <0x00>;
			};

			clk@01c20000 {
				clocks = <0x00>;
			};

			clk@01c20008 {
				clocks = <0x00>;
			};

			clk@01c20010 {
				clocks = <0x00>;
			};

			pll3x2_clk {
				clocks = <0x00>;
			};

			clk@01c20018 {
				clocks = <0x00>;
			};

			clk@01c20020 {
				clocks = <0x00>;
			};

			clk@01c20028 {
				clocks = <0x00>;
			};

			clk@01c20030 {
				clocks = <0x00>;
			};

			pll7x2_clk {
				clocks = <0x00>;
			};

			cpu@01c20054 {
				clocks = <0x00 0x04 0x08 0x0c>;
			};

			axi@01c20054 {
				clocks = <0x00>;
			};

			ahb@01c20054 {
				clocks = <0x00 0x04 0x08>;
				assigned-clocks = <0x00>;
				assigned-clock-parents = <0x00>;
			};

			apb0@01c20054 {
