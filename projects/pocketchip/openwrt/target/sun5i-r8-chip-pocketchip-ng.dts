// SPDX-License-Identifier: GPL-2.0+ OR X11
/*
 * Device tree for the Next Thing Co. PocketCHIP handheld.
 *
 * Derived from arch/arm/boot/dts/allwinner/sun5i-r8-chip.dts (mainline)
 * with the PocketCHIP daughterboard additions appended below the line
 * marked "PocketCHIP daughterboard". The chip.dts content is inlined
 * rather than included, because chip.dts is itself a board-level .dts
 * (with /dts-v1/; and C-preprocessor #includes) and is not directly
 * reusable as a fragment.
 *
 * Daughterboard adds:
 *   - 4.3" 480x272 parallel RGB LCD with resistive touch
 *   - PWM backlight on PB2
 *   - QWERTY keyboard matrix (wiring TODO; see comment below)
 *
 * Composite TV-out via the TRRS jack stays available (chip.dts already
 * enables tve0). LCD and TVE share TCON0 channels but expose separate
 * DRM connectors, so userspace picks which output is active.
 *
 * Audio (sun4i-codec) and WiFi/BT (RTL8723BS) are already wired up in
 * chip.dts; we just inherit them.
 *
 * Note: the R8 only routes 18-bit (RGB666) LCD pins externally, so the
 * panel runs 6 bits per channel even though the screen is 24-bit
 * capable. At 4.3" the difference is invisible.
 */

/dts-v1/;
#include "sun5i-r8.dtsi"
#include "sunxi-common-regulators.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Next Thing Co. PocketCHIP (mainline)";
	compatible = "nextthing,pocketchip", "nextthing,chip",
		     "allwinner,sun5i-r8", "allwinner,sun5i-a13";

	aliases {
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		serial0 = &uart1;
		serial1 = &uart3;
		spi0 = &spi2;
	};

	chosen {
		/*
		 * Two parallel kernel consoles:
		 *   tty0    -> LCD framebuffer (visible after DRM brings up the panel)
		 *   ttyGS0  -> USB CDC-ACM gadget over the OTG port. When you plug
		 *              the PocketCHIP into a host machine it shows up as
		 *              /dev/cu.usbmodem* (macOS) or /dev/ttyACM* (Linux).
		 * serial0 (UART1) is still the bootloader/early-debug console if
		 * a 3.3 V USB-UART dongle is wired up to the test points.
		 */
		stdout-path = "serial0:115200n8";
		bootargs = "console=tty0 console=ttyGS0,115200 root=/dev/ram0 rw rootwait loglevel=4 panic=10";
	};

	leds {
		compatible = "gpio-leds";

		led-0 {
			label = "chip:white:status";
			gpios = <&axp_gpio 2 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};
	};

	mmc0_pwrseq: pwrseq {
		compatible = "mmc-pwrseq-simple";
		reset-gpios = <&pio 2 19 GPIO_ACTIVE_LOW>; /* PC19 */
	};

	onewire {
		compatible = "w1-gpio";
		gpios = <&pio 3 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; /* PD2 */
	};

	/* ===== PocketCHIP daughterboard ===== */

	backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pwm 0 50000 0>;          /* 20 kHz */
		brightness-levels = <0 16 32 48 64 80 96 112 128 160 192 224 255>;
		default-brightness-level = <8>;
		power-supply = <&reg_vcc3v3>;
	};

	panel: panel {
		/*
		 * Generic 4.3" 480x272 parallel-RGB panel. NTC used a
		 * Powertip-class display; the timings here are the
		 * community-known-good baseline. If colors look smeared
		 * or the picture wobbles, the first thing to revisit is
		 * the pixelclk-active polarity, not the porch values.
		 */
		compatible = "powertip,ph480272t-005-i06q", "simple-panel";
		backlight = <&backlight>;
		power-supply = <&reg_vcc3v3>;

		panel-timing {
			clock-frequency = <9000000>;
			hactive = <480>;
			vactive = <272>;
			hfront-porch = <2>;
			hback-porch = <2>;
			hsync-len = <41>;
			vfront-porch = <2>;
			vback-porch = <2>;
			vsync-len = <10>;
			hsync-active = <0>;
			vsync-active = <0>;
			de-active = <1>;
			pixelclk-active = <1>;
		};

		port {
			panel_in: endpoint {
				remote-endpoint = <&tcon0_out_lcd>;
			};
		};
	};
};

&be0 {
	status = "okay";
};

&codec {
	status = "okay";
};

&cpu0 {
	cpu-supply = <&reg_dcdc2>;
};

&ehci0 {
	status = "okay";
};

&i2c0 {
	status = "okay";

	axp209: pmic@34 {
		reg = <0x34>;
		interrupts = <0>;
	};
};

#include "axp209.dtsi"

&ac_power_supply {
	status = "okay";
};

&battery_power_supply {
	status = "okay";
};

&i2c1 {
	status = "disabled";
};

&i2c2 {
	status = "okay";

	xio: gpio@38 {
		compatible = "nxp,pcf8574a";
		reg = <0x38>;

		gpio-controller;
		#gpio-cells = <2>;

		interrupt-parent = <&pio>;
		interrupts = <6 0 IRQ_TYPE_EDGE_FALLING>;
		interrupt-controller;
		#interrupt-cells = <2>;
	};
};

&mmc0_pins {
	bias-pull-up;
};

&mmc0 {
	vmmc-supply = <&reg_vcc3v3>;
	mmc-pwrseq = <&mmc0_pwrseq>;
	bus-width = <4>;
	non-removable;
	status = "okay";
};

&ohci0 {
	status = "okay";
};

&otg_sram {
	status = "okay";
};

&reg_dcdc2 {
	regulator-min-microvolt = <1000000>;
	regulator-max-microvolt = <1400000>;
	regulator-name = "cpuvdd";
	regulator-always-on;
};

&reg_dcdc3 {
	regulator-min-microvolt = <1000000>;
	regulator-max-microvolt = <1300000>;
	regulator-name = "corevdd";
	regulator-always-on;
};

&reg_ldo1 {
	regulator-name = "rtcvdd";
};

&reg_ldo2 {
	regulator-min-microvolt = <2700000>;
	regulator-max-microvolt = <3300000>;
	regulator-name = "avcc";
	regulator-always-on;
};

/* LDO3 + LDO4 power the WiFi/BT chip; both required. */
&reg_ldo3 {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	regulator-name = "vcc-wifi-1";
	regulator-always-on;
};

&reg_ldo4 {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	regulator-name = "vcc-wifi-2";
	regulator-always-on;
};

&reg_ldo5 {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
	regulator-name = "vcc-1v8";
};

&reg_usb0_vbus {
	vin-supply = <&reg_vcc5v0>;
	gpio = <&pio 1 10 GPIO_ACTIVE_HIGH>; /* PB10 */
	status = "okay";
};

&spi2 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi2_pe_pins>;
	status = "disabled";
};

/*
 * LCD wiring: TCON0's RGB output is endpoint@0 (channel 0). The TVE
 * (composite) endpoint@1 is already declared in the SoC dtsi; both
 * coexist so DRM can switch between LCD and composite at runtime.
 */
&tcon0 {
	pinctrl-names = "default";
	pinctrl-0 = <&lcd_rgb666_pins>;
	status = "okay";

	ports {
		port@1 {
			tcon0_out_lcd: endpoint@0 {
				reg = <0>;
				allwinner,tcon-channel = <0>;
				remote-endpoint = <&panel_in>;
			};
		};
	};
};

&tve0 {
	status = "okay";
};

&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_pg_pins>;
	status = "okay";
};

&uart3 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart3_pg_pins>,
		    <&uart3_cts_rts_pg_pins>;
	status = "okay";

	bluetooth {
		compatible = "realtek,rtl8723bs-bt";
		device-wake-gpios = <&axp_gpio 3 GPIO_ACTIVE_HIGH>;
		host-wake-gpios = <&pio 1 3 GPIO_ACTIVE_HIGH>; /* PB3 */
	};
};

/*
 * USB OTG: leave as 'otg' (matches mainline chip.dts and the only
 * known-working community PocketCHIP DT, macromorgan/chip-debroot).
 * Forcing dr_mode = "peripheral" boots on kernel 6.6 but breaks on
 * 6.12 -- the musb-sunxi driver in 6.12 stops enumerating in
 * peripheral mode when ID GPIO is also declared in &usbphy. Stick
 * with OTG and let the kernel detect mode via ID GPIO on PG2; when
 * a USB host (the Mac) is attached, VBUS comes from the host and ID
 * floats high, which the driver reads as peripheral mode.
 */
&usb_otg {
	dr_mode = "otg";
	status = "okay";
};

&usb_power_supply {
	status = "okay";
};

&usbphy {
	status = "okay";

	usb0_id_det-gpios = <&pio 6 2 GPIO_ACTIVE_HIGH>; /* PG2 */
	usb0_vbus_power-supply = <&usb_power_supply>;
	usb0_vbus-supply = <&reg_usb0_vbus>;
	usb1_vbus-supply = <&reg_vcc5v0>;
};

/* PWM0 on PB2 drives the LCD backlight. */
&pwm {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm0_pin>;
	status = "okay";
};

/*
 * Resistive touchscreen — the R8's integrated RTP controller does the
 * 4-wire ADC sampling. The sun4i-ts driver binds this node directly.
 */
&rtp {
	allwinner,ts-attached;
	status = "okay";
};

/* TODO: keyboard matrix.
 *
 * The QWERTY keyboard rows/cols sit on a mix of pins (parts of the CSI
 * bank on PE, plus the PCF8574A I2C expander 'xio' on i2c2 @ 0x38).
 * Exact mapping varies across PocketCHIP revisions; needs a multimeter
 * check on the actual board before claiming pins, otherwise we risk
 * pinmux conflicts with the LCD or USB and lock the board up.
 *
 * Power button via the AXP209 PEK (axp20x-pek driver) is already a
 * working input device, so we are not totally without input on first
 * boot.
 */
