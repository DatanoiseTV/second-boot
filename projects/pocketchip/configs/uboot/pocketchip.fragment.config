# U-Boot config fragment appended to CHIP_defconfig.
# Hardcodes a bootcmd that boots a kernel pre-staged in DDR by sunxi-fel.

CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTCOMMAND="bootz 0x42000000 - 0x43000000"

CONFIG_USE_BOOTARGS=y
# ttyGS0 listed LAST so /dev/console reads its input from the USB ACM
# gadget rather than from the LCD's tty0 (which has no keyboard wired).
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 loglevel=4 panic=10"

# Trim the boot delay so the smoke test starts fast.
CONFIG_BOOTDELAY=0
