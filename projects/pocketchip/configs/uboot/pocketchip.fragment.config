# U-Boot config fragment appended to CHIP_defconfig.
#
# Two key choices baked in:
#
# 1. CDC-ACM gadget console.
#    We have no physical UART available on the PocketCHIP (no serial
#    dongle, the test points behind the LCD are not wired up). Without
#    some way to see U-Boot output we cannot tell whether a failed boot
#    is U-Boot dying, the kernel panicking, or just slow.
#    The Allwinner SoC supports a USB gadget mode out of U-Boot;
#    enabling CONFIG_USB_FUNCTION_ACM gives us a /dev/cu.usbmodem*
#    console as soon as the USB cable is plugged into a host.
#    Bootcmd switches stdout/stdin to that gadget before issuing bootm
#    so we see "Booting kernel" / any error path.
#
# 2. 'bootm' instead of 'bootz'.
#    OpenWrt's initramfs-kernel.bin is a u-boot legacy uImage (load
#    0x40008000, OS Kernel Image type) -- not a raw zImage. bootz would
#    silently fail on it. bootm auto-detects the format.

CONFIG_USE_BOOTCOMMAND=y
# 'sleep 3' after the stdio switch gives the host enough time to open
# /dev/cu.usbmodem* and start reading before bootm prints anything.
CONFIG_BOOTCOMMAND="setenv stdout usbacm; setenv stdin usbacm; sleep 3; echo === pocketchip-ng u-boot ===; bootm 0x42000000 - 0x43000000"

CONFIG_USE_BOOTARGS=y
# ttyGS0 listed LAST so /dev/console reads its input from the USB ACM
# gadget rather than from the LCD's tty0 (which has no keyboard wired).
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 loglevel=8 panic=10"

# Trim the boot delay so the smoke test starts fast.
CONFIG_BOOTDELAY=0

# --- USB gadget bring-up for console-over-USB ----------------------------
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_DOWNLOAD=y
CONFIG_USB_GADGET_VENDOR_NUM=0x1d6b
CONFIG_USB_GADGET_PRODUCT_NUM=0x0104
CONFIG_USB_GADGET_MANUFACTURER="DatanoiseTV"
CONFIG_USB_FUNCTION_ACM=y
CONFIG_DM_USB_GADGET=y
