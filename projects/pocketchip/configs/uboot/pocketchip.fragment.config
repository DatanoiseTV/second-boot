# U-Boot config fragment appended to CHIP_defconfig.
#
# Minimal: just override the bootcmd and bootargs. We do NOT enable
# the USB gadget driver in U-Boot itself -- the experiment showed that
# even an inactive gadget driver compiled in can leave the OTG
# controller in a state the kernel struggles to take over, breaking
# the kernel's USB gadget enumeration. Keep U-Boot's USB stack at
# host-only so the controller is in its BootROM/default state when
# Linux probes it.
#
# Boot order: 'bootz' first, 'bootm' as fallback. Our installer kernel
# (and the busybox kernel) is a RAW zImage (magic 0x016f2818) -- bootm
# only understands the u-boot legacy/FIT header (magic 0x27051956) and
# bails out with "Bad Magic Number" on a raw zImage, booting nothing.
# That is exactly why FEL RAM-boots produced no LED/no enumeration after
# we'd switched this to bootm-only. bootz boots the raw zImage and never
# returns on success; if it ever fails (e.g. a uImage is staged instead)
# u-boot falls through to bootm. This covers both image formats.

CONFIG_USE_BOOTCOMMAND=y
# DTB at 0x49000000, NOT 0x43000000: our installer kernel (OpenWrt
# embedded) is ~16.4 MB and loaded at 0x42000000 would run past
# 0x43000000, so a DTB staged there gets clobbered by the kernel image
# (and vice-versa). 0x49000000 sits 112 MB above the kernel and just
# below u-boot's TEXT_BASE (0x4A000000) -- clear of both the compressed
# image and the decompressed kernel.
CONFIG_BOOTCOMMAND="bootz 0x42000000 - 0x49000000; bootm 0x42000000 - 0x49000000"

CONFIG_USE_BOOTARGS=y
# ubi.mtd=4 auto-attaches the NAND rootfs UBI as ubi0 at boot (the DTS
# now enables &nfc with rootfs as the 5th partition). Lets the busybox
# initramfs `mount -t ubifs ubi0:rootfs /mnt` to reach /boot for
# installing OpenWrt -- busybox has no ubiattach, but built-in UBI
# auto-attaches from this cmdline.
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 ubi.mtd=4 loglevel=8 panic=10"

CONFIG_BOOTDELAY=0
