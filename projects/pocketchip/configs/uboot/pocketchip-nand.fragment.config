# U-Boot config fragment for NAND-resident builds.
# Use on top of CHIP_defconfig instead of pocketchip.fragment.config
# when building the U-Boot that will ultimately live in NAND.
#
# This bootcmd reads kernel + dtb out of a UBIFS volume named "boot"
# inside the UBI partition "UBI". The rootfs is in volume "rootfs"
# and is mounted ubi0:rootfs via the kernel cmdline.

CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTCOMMAND="ubi part UBI && ubifsmount ubi0:boot && ubifsload 0x42000000 zImage && ubifsload 0x43000000 chip-pocketchip-ng.dtb && bootz 0x42000000 - 0x43000000"

CONFIG_USE_BOOTARGS=y
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 ubi.mtd=UBI root=ubi0:rootfs rootfstype=ubifs rw loglevel=4 panic=10"

# Slightly longer delay than the RAM-boot variant so a serial console
# user can interrupt and recover if needed.
CONFIG_BOOTDELAY=2

# Save env to NAND so 'saveenv' from u-boot persists across reboots.
CONFIG_ENV_IS_IN_NAND=y
# Keep the same offset as the original NTC layout, leaving room for a
# second-stage U-Boot copy in case the primary corrupts.
CONFIG_ENV_OFFSET=0x800000
CONFIG_ENV_SIZE=0x40000

# CHIP NAND has Hynix/Toshiba/SanDisk MLC across revisions. The driver
# probes ONFI so we don't hard-code timings; this just enables the
# subsystem in u-boot.
CONFIG_CMD_NAND=y
CONFIG_CMD_NAND_TRIMFFS=y
CONFIG_NAND_SUNXI=y
CONFIG_CMD_UBI=y
CONFIG_CMD_UBIFS=y
CONFIG_MTD=y
CONFIG_MTD_DEVICE=y
CONFIG_MTD_RAW_NAND=y
