# U-Boot config fragment for a "flash NAND then reset" U-Boot.
# Appended to CHIP_defconfig.
#
# Deliberately does NOT change CONFIG_ENV_IS_IN_* -- touching the env
# storage choice conflicts with CHIP_defconfig's existing choice and
# makes Kconfig prompt interactively, which hangs a headless build. We
# don't need persistent env for the flasher: the flash sequence is a
# U-Boot script we stage in DDR via sunxi-fel and run with 'source'.
#
# We only add the NAND + UBI commands and the sunxi NAND driver so the
# script can erase/write the on-board NAND from data pre-staged in DDR.

CONFIG_MTD=y
CONFIG_MTD_RAW_NAND=y
CONFIG_NAND_SUNXI=y
CONFIG_CMD_NAND=y
CONFIG_CMD_MTD=y
CONFIG_CMD_UBI=y
CONFIG_CMD_UBIFS=y

# NAND geometry. These compile-time values have no Kconfig default, so
# they MUST be set or `make` loops forever prompting on a headless
# build. CONFIG_SYS_NAND_ONFI_DETECTION=y means u-boot reads the real
# geometry from the chip's ONFI parameter page at runtime; these are
# the SPL-time fallbacks. Values taken from CHIP_pro_defconfig (the
# NAND-booting sunxi reference) -- safe because ONFI overrides them.
CONFIG_SYS_MAX_NAND_DEVICE=8
CONFIG_SYS_NAND_ONFI_DETECTION=y
CONFIG_SYS_NAND_PAGE_SIZE=0x1000
CONFIG_SYS_NAND_OOBSIZE=0x100
CONFIG_SYS_NAND_BLOCK_SIZE=0x40000
CONFIG_SYS_NAND_MAX_ECCPOS=1664
CONFIG_MTDIDS_DEFAULT="nand0=sunxi-nand.0"
CONFIG_MTDPARTS_DEFAULT="mtdparts=sunxi-nand.0:1m(spl),3m(uboot),-(UBI)"
CONFIG_CMD_MTDPARTS=y

# On start, run the FEL-staged flash script at 0x7f000000 (SRAM-safe,
# well clear of the SPL/u-boot/UBI staging addresses in DDR).
CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTCOMMAND="source 0x7f000000"
CONFIG_BOOTDELAY=0
