# U-Boot config fragment for the NAND-RESIDENT u-boot (the one that
# lives in NAND and boots the system on every cold boot). Appended to
# CHIP_defconfig.
#
# These NAND/boot symbols mirror macromorgan's PROVEN working PocketCHIP
# CHIP_defconfig (the reverse-engineered mainline NAND build). The single
# most important one is CONFIG_NAND_BOOT=y: it makes the build target NAND
# as the boot medium, which (a) builds the SPL with the correct boot0/eGON
# header the BootROM expects, and (b) triggers generation of
# sunxi-spl-with-ecc.bin -- the ECC+scramble-wrapped boot0 that gets
# written raw to NAND 0x0/0x400000. Without it the BootROM rejects our SPL
# and drops to FEL (which is exactly what we hit).
#
# Layout (matches macromorgan + U-Boot board/sunxi/README.nand):
#   0x000000  SPL (boot0) copy 1   <- BootROM loads this
#   0x400000  SPL (boot0) copy 2
#   0x800000  u-boot proper        <- SYS_NAND_U_BOOT_OFFS
#   0xc00000  env (ENV_IS_IN_NAND)
#   0x1000000 bootfs: kernel uImage + DTB (32 MiB)
#   0x3000000 rootfs: slc-mode UBI (Stage 2)

# --- boot medium: NAND (THE missing piece) ---------------------------------
CONFIG_NAND_BOOT=y

# --- NAND core + commands --------------------------------------------------
CONFIG_MTD=y
CONFIG_MTD_RAW_NAND=y
CONFIG_NAND_SUNXI=y
CONFIG_SYS_NAND_SELF_INIT=y
CONFIG_SYS_NAND_USE_FLASH_BBT=y
CONFIG_CMD_NAND=y
CONFIG_CMD_MTD=y
CONFIG_CMD_UBI=y
CONFIG_CMD_UBIFS=y
CONFIG_MTD_UBI=y

# --- NAND geometry (Toshiba TC58TEG5DCLTA00: 16K page / 1280 OOB / 4M) -----
CONFIG_SYS_NAND_BLOCK_SIZE=0x400000
CONFIG_SYS_NAND_PAGE_SIZE=0x4000
CONFIG_SYS_NAND_OOBSIZE=0x500

# --- SPL boot0 ECC (BootROM-fixed: 64-bit/1024, usable 4096) ---------------
CONFIG_SPL_NAND_SUPPORT=y
CONFIG_SPL_MTD_SUPPORT=y
CONFIG_NAND_SUNXI_SPL_ECC_STRENGTH=64
CONFIG_NAND_SUNXI_SPL_ECC_SIZE=1024
CONFIG_NAND_SUNXI_SPL_USABLE_PAGE_SIZE=4096
CONFIG_SYS_NAND_U_BOOT_LOCATIONS=y
CONFIG_SYS_NAND_U_BOOT_OFFS=0x800000
CONFIG_SYS_NAND_U_BOOT_OFFS_REDUND=0x800000

# --- env in NAND (matches the 0xc00000 env partition) ----------------------
CONFIG_ENV_IS_IN_NAND=y
CONFIG_ENV_OFFSET=0xc00000
CONFIG_ENV_SIZE=0x400000

# --- boot: read kernel uImage + DTB from bootfs and bootm ------------------
CONFIG_USE_BOOTCOMMAND=y
# bootfs at 0x1000000 (32 MiB). Kernel uImage up to 28 MiB, DTB at 0x2e00000.
CONFIG_BOOTCOMMAND="nand read 0x42000000 0x1000000 0x1c00000; nand read 0x49000000 0x2e00000 0x20000; bootm 0x42000000 - 0x49000000"
CONFIG_BOOTDELAY=1

CONFIG_USE_BOOTARGS=y
# Stage 1 runs entirely from the uImage's embedded initramfs. Stage 2
# switches this to ubi.mtd=5 root=ubi0:rootfs rootfstype=ubifs.
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 loglevel=8 panic=10"
