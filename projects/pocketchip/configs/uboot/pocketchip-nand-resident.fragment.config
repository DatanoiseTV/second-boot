# U-Boot config fragment for the NAND-RESIDENT u-boot (the one that
# lives in NAND and boots the system on every cold boot). Appended to
# CHIP_defconfig.
#
# Boots a raw kernel image + DTB read straight out of NAND -- no UBI,
# no filesystem. The kernel is OpenWrt's initramfs-kernel uImage, which
# carries the entire root filesystem as an embedded initramfs, so there
# is no separate rootfs partition to mount and no geometry-sensitive
# UBIFS. This is the geometry-robust path: only the SPL ECC layout
# depends on NAND geometry, and if that's wrong the board simply falls
# back to FEL (recoverable, not bricked).
#
# NAND layout (see scripts/30-fel-flash-nand.sh):
#   0x000000  SPL (ECC) x4 copies at 0x0/0x100000/0x200000/0x300000
#   0x400000  this u-boot (proper)
#   0x800000  OpenWrt uImage (kernel + initramfs)
#   0x1800000 DTB

CONFIG_MTD=y
CONFIG_MTD_RAW_NAND=y
CONFIG_NAND_SUNXI=y
CONFIG_CMD_NAND=y
CONFIG_CMD_MTD=y

CONFIG_SYS_MAX_NAND_DEVICE=8
CONFIG_SYS_NAND_ONFI_DETECTION=y
CONFIG_SYS_NAND_PAGE_SIZE=0x4000
CONFIG_SYS_NAND_OOBSIZE=0x500
CONFIG_SYS_NAND_BLOCK_SIZE=0x400000
CONFIG_SYS_NAND_MAX_ECCPOS=1664
# SPL (boot0) loads u-boot proper from this NAND offset. Must match
# where the flash script writes u-boot (0x400000).
CONFIG_SYS_NAND_U_BOOT_OFFS=0x400000
CONFIG_SPL_NAND_SUPPORT=y

CONFIG_USE_BOOTCOMMAND=y
# Read uImage (up to 16 MiB) + DTB from NAND into DRAM, then bootm.
CONFIG_BOOTCOMMAND="nand read 0x42000000 0x800000 0x1000000; nand read 0x43000000 0x1800000 0x40000; bootm 0x42000000 - 0x43000000"
CONFIG_BOOTDELAY=1

CONFIG_USE_BOOTARGS=y
CONFIG_BOOTARGS="console=tty0 console=ttyGS0,115200 loglevel=8 panic=10"
